# API 服务配置（复制到 api/.env）
# root 必须填写你本机 MySQL 的真实密码（Homebrew 安装时通常已设置密码）
DATABASE_URL="mysql://root:你的MySQL密码@localhost:3306/mina"
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"
PORT=3000
NODE_ENV=development
# 管理后台来源，生产环境逗号分隔多个（须与浏览器地址栏 Origin 完全一致）
CORS_ORIGIN="http://localhost:5173,https://admin.mina.bigdeng.com"

# 初始管理员（仅 seed 时使用，勿提交真实密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456

# 小程序
JWT_USER_SECRET=change-me-user-jwt-secret-32chars
# 小程序等 C 端接口图片绝对路径前缀；须为 https 且域名正确（如 https://api.mina.bigdeng.com）
API_PUBLIC_URL=https://api.mina.bigdeng.com
WECHAT_APPID=
WECHAT_SECRET=
# 小程序码环境：release | trial | develop（默认 release）
# WECHAT_ENV_VERSION=release
WECHAT_DEV_OPENID=dev_openid_local
WECHAT_DEV_PHONE=13800000000

# ---------- 微信支付 V3（板布在线支付，配置在 api/.env）----------
# 商户号（微信支付商户平台）
WECHAT_MCH_ID=
# APIv3 密钥（32 位，商户平台 → 账户中心 → API 安全）
WECHAT_PAY_API_V3_KEY=
# 兼容旧变量名（与 WECHAT_PAY_API_V3_KEY 二选一即可）
WECHAT_PAY_API_KEY=
# 商户 API 证书序列号（openssl x509 -in apiclient_cert.pem -noout -serial）
WECHAT_MCH_SERIAL_NO=
# 商户私钥与证书路径（相对 api/ 目录；勿提交 git，见 api/certs/.gitkeep）
WECHAT_MCH_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_MCH_CERT_PATH=./certs/apiclient_cert.pem
# 或直接写入 PEM 内容（多行用 \n 转义，与 PATH 二选一）
# WECHAT_MCH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...
