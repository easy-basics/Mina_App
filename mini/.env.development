# 本地开发（微信开发者工具请用 127.0.0.1，不要用 localhost）
VITE_API_BASE_URL=http://127.0.0.1:3000/api
VITE_ASSET_BASE_URL=http://127.0.0.1:3000

# H5 本地开发自动登录（npm run dev:h5）；设为 false 可手动测登录流程
VITE_DEV_AUTO_LOGIN=true
# 可选：模拟用户资料（仅 H5 dev 生效）
VITE_DEV_MOCK_AVATAR=/static/logo.svg
VITE_DEV_MOCK_REAL_NAME=开发用户
VITE_DEV_MOCK_PHONE=13800000000
VITE_DEV_MOCK_COMPANY=开发公司
